# Juno Mission Control Dashboard Environment Variables

## Market Data Configuration

### Finnhub API (Recommended for Stocks/ETFs)
# Get your free API key at: https://finnhub.io/register
# Free tier: 60 calls/minute, real-time US market data
FINNHUB_API_KEY=your_finnhub_api_key_here

### Alpha Vantage (Alternative)
# Get your free API key at: https://www.alphavantage.co/support/#api-key
# Free tier: 25 calls/day
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Market Data Provider Preference
MARKET_DATA_PROVIDER=finnhub

## Google Calendar (OAuth2 — works with personal Gmail, no Workspace admin needed)
# 1. Create a project at https://console.cloud.google.com/
# 2. Enable the Google Calendar API
# 3. Create an OAuth 2.0 Client ID (Desktop app type)
# 4. Run: node scripts/get-google-refresh-token.mjs to get your refresh token
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_CALENDAR_ID=your_email@gmail.com

# Legacy service account fallback (optional — only needed if not using OAuth2 above)
# GOOGLE_SERVICE_ACCOUNT_JSON=base64_encoded_service_account_json

## Redis (for caching)
REDIS_URL=redis://localhost:6379

## Strava API (for activity tracking)
# Get your API credentials at: https://www.strava.com/settings/api
# 1. Create an app at https://www.strava.com/settings/api
# 2. Copy Client ID and Client Secret
# 3. To get a refresh token, use the Strava OAuth flow or API playground
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
# Initial refresh token (get from Strava OAuth flow)
STRAVA_REFRESH_TOKEN=your_strava_refresh_token

## Anthropic API (for AI-powered journal insights)
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

## ConfluenceTrading (agentic swing-trading — owner-only)
# Agent run mode:
#  'deterministic' (default) — FundamentalsProvider + code strategy; runs the
#     mock provider credential-free, so paper mode always works.
#  'claude' — the real agent: a Claude MCP-client call reads fundamentals via the
#     READ-ONLY Robinhood MCP connector and returns candidates. Needs ANTHROPIC_API_KEY
#     + ROBINHOOD_MCP_TOKEN (below). The order tools are never enabled — the agent
#     cannot place trades.
CONFLUENCE_AGENT_MODE=deterministic
# Model for the Claude analyst (claude mode only).
CONFLUENCE_AGENT_MODEL=claude-opus-4-8
# Which fundamentals data source the deterministic mode screens with.
# 'mock' (default) needs no credentials. Switch to 'robinhood' or 'massive'
# once the creds below are set.
CONFLUENCE_FUNDAMENTALS_PROVIDER=mock
# Screening universe (exact tickers, comma-separated) for the robinhood/massive
# providers. Defaults to a small large-cap set if unset.
CONFLUENCE_UNIVERSE=AAPL,MSFT,GOOGL,AMZN,NVDA,META,KO,JNJ,PG,JPM
# Strategy the deterministic mode (and the Claude analyst's <criteria>) runs.
# Defaults to value-ta-pullback; see lib/confluence/agent/strategies/.
CONFLUENCE_STRATEGY=value-ta-pullback
# Bar source for the technical gate. 'mock' is only valid alongside mock
# fundamentals (the factory refuses real fundamentals + mock bars). Set to
# 'robinhood' for any real run.
CONFLUENCE_TECHNICALS_PROVIDER=mock
# Risk budget per trade in dollars (drives share sizing off the stop distance).
# Defaults to 1% of the total exposure cap — set explicitly for small accounts.
CONFLUENCE_RISK_PER_TRADE_USD=
# Model for the weekly performance-review narrator (Milestone R). The reviewer
# is tool-less and read-only: it narrates metrics the code already computed.
CONFLUENCE_REVIEW_MODEL=claude-opus-4-8
# --- Live execution (Milestone 3) — REAL orders. Off unless ALL of these hold. ---
# Deploy-level kill flag: real orders are refused unless this is exactly 'true',
# even if the UI is flipped to live mode. Leave unset for paper-only.
CONFLUENCE_ALLOW_LIVE=
# --- Robinhood MCP (fundamentals read + live order rail) ---
# Robinhood agentic is OAuth 2.1 + PKCE (no static API key). Two ways to auth,
# see docs/CONFLUENCE_ROBINHOOD_TOKEN.md:
#   (A) DURABLE — capture a refresh token once; the app auto-refreshes access
#       tokens and caches them (survives rotation). Set:
ROBINHOOD_OAUTH_CLIENT_ID=
ROBINHOOD_OAUTH_REFRESH_TOKEN=
# ROBINHOOD_OAUTH_TOKEN_URL=https://api.robinhood.com/oauth2/token/   # default
#   (B) MANUAL — paste a short-lived access token (fine for a one-off test).
ROBINHOOD_MCP_TOKEN=
# MCP endpoint (rarely changes).
ROBINHOOD_MCP_URL=https://agent.robinhood.com/mcp/trading
# NOTE: the deployed-app MCP transport + live order placement have NOT been
# validated end to end — verify against the small funded agentic account with
# tiny caps and the kill switch handy before trusting it.
# --- Massive provider (fundamentals ratios) ---
# Requires the Massive "Financials & Ratios Expansion" (or Stocks Advanced/Business).
MASSIVE_API_KEY=
# MASSIVE_API_URL=https://api.massive.com

## Next.js / Auth
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth session signing key — REQUIRED in production.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-32-char-random-secret-here

# Secret used to authenticate Vercel cron job requests.
# Set this in Vercel and in vercel.json → crons headers.
# Generate with: openssl rand -base64 32
CRON_SECRET=your-cron-secret-here

# Bearer token for headless Claude agents (Collaborative Goals agent AND the
# ConfluenceTrading scheduled agent) to call /api/goals/agent and
# /api/confluence/agent/* without a browser session. See docs/CONFLUENCE_AGENT.md.
# Generate with: openssl rand -base64 32
AGENT_SECRET=your-agent-secret-here

# Skip gateway connection in dev
GATEWAY_URL=http://localhost:18789
GATEWAY_TOKEN=dev
