{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "functions": {
    "app/api/gap-scanner/route.ts": {
      "maxDuration": 300
    },
    "app/api/intraday-movers/route.ts": {
      "maxDuration": 120
    },
    "app/api/cron-jobs/gap-scanner-trigger/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron-jobs/market-briefing/route.ts": {
      "maxDuration": 120
    },
    "app/api/cron-jobs/avg-volume-daily/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron-jobs/avg-volume-backfill/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron-jobs/intraday-alerts/route.ts": {
      "maxDuration": 120
    },
    "app/api/cron-jobs/confluence-agent/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron-jobs/confluence-weekly-review/route.ts": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/cron-jobs/gap-scanner-trigger",
      "schedule": "30 11 * * 1-5"
    },
    {
      "path": "/api/cron/daily-motivational",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron-jobs/market-briefing",
      "schedule": "0 12 * * 1-5"
    },
    {
      "path": "/api/cron-jobs/avg-volume-daily",
      "schedule": "0 23 * * 1-5"
    },
    {
      "path": "/api/cron-jobs/seed-daily-favorites",
      "schedule": "0 12 * * 1-5"
    },
    {
      "path": "/api/cron-jobs/intraday-alerts",
      "schedule": "*/30 14-21 * * 1-5"
    },
    {
      "path": "/api/cron-jobs/reset-recurring-goals",
      "schedule": "5 5 * * *"
    },
    {
      "path": "/api/cron-jobs/confluence-agent",
      "schedule": "0 2 * * 2-6"
    },
    {
      "path": "/api/cron-jobs/confluence-weekly-review",
      "schedule": "0 13 * * 6"
    }
  ]
}
