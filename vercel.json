{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "functions": {
    "app/api/gap-scanner/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron-jobs/gap-scanner-trigger/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron-jobs/gap-scanner-trigger",
      "schedule": "30 11 * * 1-5"
    }
  ]
}
